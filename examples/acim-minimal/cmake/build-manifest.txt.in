project=@PROJECT_NAME@
project_version=@PROJECT_VERSION@
generator=@CMAKE_GENERATOR@
build_type=@CMAKE_BUILD_TYPE@
host_system=@CMAKE_HOST_SYSTEM_NAME@
target_system=@CMAKE_SYSTEM_NAME@
target_processor=@CMAKE_SYSTEM_PROCESSOR@
c_compiler_id=@CMAKE_C_COMPILER_ID@
c_compiler_version=@CMAKE_C_COMPILER_VERSION@
c_compiler=@CMAKE_C_COMPILER@
c_feature=c_std_11
cxx_compiler_id=@CMAKE_CXX_COMPILER_ID@
cxx_compiler_version=@CMAKE_CXX_COMPILER_VERSION@
cxx_compiler=@CMAKE_CXX_COMPILER@
cxx_feature=cxx_std_20
warnings_as_errors=@ACIM_WARNINGS_AS_ERRORS@
sanitizers=@ACIM_ENABLE_SANITIZERS@
google_test=@ACIM_ENABLE_GTEST@
fetch_google_test=@ACIM_FETCH_GTEST@
